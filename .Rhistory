readSequences <- function(filepath) {
# Read the file as a vector of lines, then join into one string preserving newlines
text <- readLines(filepath)
text <- paste(text, collapse = "\n")
text <- unlist(strsplit(text, ">")) # Split on > to separate entries — each split is now one name + sequence
text <- text[text != ""] # Drop anything before the first >
# Parse each chunk into a name and sequence
sequences <- lapply(text, function(entry) {
lines <- strsplit(entry, "\n")[[1]]  # split chunk into individual lines
lines <- lines[lines != ""]          # drop any blank lines
# The first line is the sequence name, all remaining lines are sequence data
list(
name     = lines[1],
sequence = paste(lines[-1], collapse = "")  # join sequence lines into one continuous string
)
})
# Collect results into a two-column data frame
data.frame(
name     = sapply(sequences, `[[`, "name"),
sequence = sapply(sequences, `[[`, "sequence"),
row.names = NULL,
stringsAsFactors = FALSE
)
}
