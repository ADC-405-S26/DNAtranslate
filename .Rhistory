getwd()
readSequences <- function(filepath) {
lines <- readLines(filepath) # read the file in as a character vector, one element per line
sequences <- list()                         # empty list to store name:sequence pairs as we find them
current_name <- NULL                        # placeholder for the sequence name we're currently on
current_seq  <- c()                         # placeholder for the sequence lines we're currently collecting
for (line in lines) {                       # loop through every line in the file
if (startsWith(line, ">")) {              # if the line starts with ">" it's a sequence header
if (!is.null(current_name)) {           # if we already have a sequence loaded, save it before moving on
sequences[[current_name]] <- paste(current_seq, collapse = "")  # collapse sequence lines into one string and save it
}
current_name <- sub("^>", "", line)     # strip the ">" from the header line and use the rest as the name
current_seq  <- c()                     # reset the sequence collector for the new sequence
} else {
current_seq <- c(current_seq, line)     # if it's not a header, it's a sequence line — append it to the collector
}
}
if (!is.null(current_name)) {              # after the loop ends, save the final sequence (loop won't save it otherwise)
sequences[[current_name]] <- paste(current_seq, collapse = "")  # same collapse-and-save as above
}
data.frame(
name     = names(sequences),             # pull the names from the list as the "name" column
sequence = unlist(sequences),            # pull the sequences from the list as the "sequence" column
row.names = NULL,                        # don't add row numbers as an extra column
stringsAsFactors = FALSE                 # keep strings as strings, not factors
)
}
