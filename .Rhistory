write.csv(df, "sequences.csv", row.names = FALSE)           # write the result to a CSV, without row numbers
View(df)
readSequences <- function(filepath) {
text <- readLines(filepath)                               # read the file as a vector of lines
text <- paste(text, collapse = "\n")                      # join all lines into one single string
text <- gsub("(?<=[A-Z])(?=>)", "\n", text, perl=TRUE)   # insert a newline wherever a letter is immediately followed by ">" (fixes merged sequences)
lines <- strsplit(text, "\n")[[1]]                        # split the string back into individual lines
sequences <- list()                                       # empty list to store name:sequence pairs
current_name <- NULL                                      # tracks the current sequence name
current_seq  <- c()                                       # collects lines belonging to the current sequence
for (line in lines) {                                     # loop through every line
if (startsWith(line, ">")) {                            # ">" means it's a header line
if (!is.null(current_name)) {                         # if we already have a sequence, save it before starting the next
sequences[[current_name]] <- paste(current_seq, collapse = "")  # join sequence lines into one string and save
}
current_name <- sub("^>", "", line)                   # remove the ">" and save the rest as the name
current_seq  <- c()                                   # reset the sequence collector
} else {
current_seq <- c(current_seq, line)                   # non-header lines are sequence data, keep collecting
}
}
sequences[[current_name]] <- paste(current_seq, collapse = "")  # save the final sequence after the loop ends
data.frame(                                               # build a two-column data frame
name     = names(sequences),                            # sequence names
sequence = unlist(sequences),                           # sequence strings
row.names = NULL,                                       # no row numbers
stringsAsFactors = FALSE                                # keep as plain strings
)
}
