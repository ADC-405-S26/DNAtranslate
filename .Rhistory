readSequences <- function(filepath) {
text <- readLines(filepath)                              # read the file as a vector of lines
text <- unlist(strsplit(paste(text, collapse=""), ">")) # split the entire file on ">" to separate entries
text <- text[text != ""]                                # drop any empty entries
sequences <- lapply(text, function(entry) {            # for each entry...
lines <- strsplit(entry, "\n")[[1]]                  # split into lines
list(name = lines[1], sequence = paste(lines[-1], collapse = ""))  # first line is name, rest is sequence
})
data.frame(
name     = sapply(sequences, `[[`, "name"),          # extract names
sequence = sapply(sequences, `[[`, "sequence"),      # extract sequences
row.names = NULL,
stringsAsFactors = FALSE
)
}
