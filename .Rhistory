View(df)
readSequences <- function(filepath) {
text <- readLines(filepath)                          # read file as lines
text <- paste(text, collapse = "\n")                 # join all lines into one big string
text <- gsub("(?<=[A-Z])(?=>)", "\n", text, perl=TRUE)  # insert a newline before any ">" that follows a sequence character
lines <- strsplit(text, "\n")[[1]]                   # split back into lines
sequences <- list()
current_name <- NULL
current_seq  <- c()
for (line in lines) {
if (startsWith(line, ">")) {
if (!is.null(current_name)) {
sequences[[current_name]] <- paste(current_seq, collapse = "")
}
current_name <- sub("^>", "", line)
current_seq  <- c()
} else {
current_seq <- c(current_seq, line)
}
}
if (!is.null(current_name)) {
sequences[[current_name]] <- paste(current_seq, collapse = "")
}
data.frame(
name     = names(sequences),
sequence = unlist(sequences),
row.names = NULL,
stringsAsFactors = FALSE
)
}
